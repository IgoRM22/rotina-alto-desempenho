rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function hasAccessConfig() {
      return exists(/databases/$(database)/documents/system/accessControl);
    }

    // The app owner's UID — always authorized.
    function isOwner() {
      return request.auth.uid == 'xTs3D5SePzed6eWo72e56oqFoBd2';
    }

    // Any email listed in allowedEmails (must be stored lowercase).
    function isAuthorizedEmail() {
      return isSignedIn()
        && userEmail() != null
        && hasAccessConfig()
        && get(/databases/$(database)/documents/system/accessControl).data.allowedEmails is list
        && get(/databases/$(database)/documents/system/accessControl).data.allowedEmails.hasAny([userEmail()]);
    }

    function isAuthorized() {
      return isOwner() || isAuthorizedEmail();
    }

    // Each authorized user can read/write only their OWN data path.
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthorized() && request.auth.uid == userId;
    }

    // Access-control document — read by any authenticated user, write by owner only.
    match /system/accessControl {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // All other paths are denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
