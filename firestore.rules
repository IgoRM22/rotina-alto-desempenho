rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      // Always lower-case so stored e-mails added via Console with mixed case still match.
      return request.auth.token.email.lower();
    }

    function hasAccessConfig() {
      return exists(/databases/$(database)/documents/system/accessControl);
    }

    // Checks if logged-in e-mail is in the allowedEmails list.
    function isAuthorizedEmail() {
      return isSignedIn()
        && userEmail() != null
        && hasAccessConfig()
        && get(/databases/$(database)/documents/system/accessControl).data.allowedEmails is list
        && get(/databases/$(database)/documents/system/accessControl).data.allowedEmails.hasAny([userEmail()]);
    }

    // Checks if logged-in e-mail is the adminEmail defined in the document.
    function isAdmin() {
      return isSignedIn()
        && userEmail() != null
        && hasAccessConfig()
        && get(/databases/$(database)/documents/system/accessControl).data.adminEmail == userEmail();
    }

    // All shared app data — readable/writable only by authorized e-mails.
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthorizedEmail();
    }

    // Access-control document.
    // - read: any authenticated user (needed to validate login before access)
    // - write: adminEmail only (set this manually in Firebase Console first)
    match /system/accessControl {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // All other paths are denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
