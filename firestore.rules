rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function hasAccessConfig() {
      return exists(/databases/$(database)/documents/system/accessControl);
    }

    // The hardcoded owner UID — always has full access.
    function isOwner() {
      return request.auth.uid == 'xTs3D5SePzed6eWo72e56oqFoBd2';
    }

    // Checks if logged-in e-mail is in the allowedEmails list (case-insensitive via lower()).
    // NOTE: emails stored in allowedEmails MUST be lowercase for this to match correctly.
    // Use the app's Settings > Controle de Acesso to add emails — they are auto-normalized.
    function isAuthorizedEmail() {
      return isSignedIn()
        && userEmail() != null
        && hasAccessConfig()
        && get(/databases/$(database)/documents/system/accessControl).data.allowedEmails is list
        && get(/databases/$(database)/documents/system/accessControl).data.allowedEmails.hasAny([userEmail()]);
    }

    // Owner by UID OR authorized e-mail.
    function isAuthorized() {
      return isOwner() || isAuthorizedEmail();
    }

    // All shared app data — readable/writable only by owner or authorized e-mails.
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthorized();
    }

    // Access-control document.
    // - read: any authenticated user (needed to validate login before access)
    // - write: owner UID only
    match /system/accessControl {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // All other paths are denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
